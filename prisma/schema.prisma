generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                Int       @id @default(autoincrement())
  username          String
  email             String    @unique
  password          String
  authProvider      String    @default("password")
  emailVerified     Boolean   @default(true)
  creds             Int       @default(0)
  jobsInDb          Int       @default(0)
  totalJobsSearched Int       @default(0)
  unlimited         Boolean   @default(false)
  atsChecksTotal    Int       @default(0)
  pdfUploadsTotal   Int       @default(0)
  ratings           Rating[]
  resume            Resume?
  jobs              Job[]
  jobUsage          JobUsage?
  featureUsage      FeatureUsage[]
  otps              Otp[]
  creditHistory     CreditHistory[]
}

model CreditHistory {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credits   Int      // The amount changed (e.g., -3 or +10)
  reason    String   // Detailed reason (e.g., "ATS Score Check", "Starter Pack Purchase")
  createdAt DateTime @default(now())

  @@index([userId])
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  createdAt DateTime @default(now())
  expiresAt DateTime
  purpose   String   @default("signup")
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Rating {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  score     Int
  comment   String?
  template  String
  createdAt DateTime @default(now())
}

model Resume {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int      @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model Job {
  id       String @id @default(cuid())
  userId   Int
  searchId String

  jobTitle           String
  companyName        String
  jobDescription     String   @db.Text
  skillsRequired     String[]
  experienceRequired String?
  location           String?
  salary             String?
  jobLink            String
  postedDate         String?
  source             String?

  matchScore         Int
  fitLabel           String
  missingSkills      String[]
  strengths          String[]
  reasoning          String   @db.Text
  aiSummary          String?  @db.Text
  whyItMatches       String?  @db.Text
  resumeImprovements String[]

  tier      String
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([searchId])
  @@index([expiresAt])
}

model JobUsage {
  id           String    @id @default(cuid())
  userId       Int       @unique
  date         String
  searchCount  Int       @default(0)
  jobsFetched  Int       @default(0)
  tier         String    @default("free")
  credits      Int       @default(0)
  creditsUsed  Int       @default(0)
  lastSearchAt DateTime?
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeatureUsage {
  id            String   @id @default(cuid())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  date          String
  atsUsed       Int      @default(0)
  pdfUsed       Int      @default(0)
  updatedAt     DateTime @updatedAt
  
  @@unique([userId, date])
}
